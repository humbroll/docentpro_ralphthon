# Amadeus - Flight & destination search (https://developers.amadeus.com)
# OAuth2: SDK handles token refresh automatically
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# LiteAPI - Hotel search and pricing (https://www.liteapi.travel)
# Two separate keys required:
LITEAPI_API_KEY_SEARCH=       # Normal User Group — GET /data/hotels
LITEAPI_API_KEY_RATES=        # Closed User Group — POST /hotels/min-rates

# Weather: Open-Meteo Historical API (https://open-meteo.com)
# No API key required — free and open

# PostgreSQL (optional for MVP)
DATABASE_URL=postgresql://triptiming:triptiming@postgres:5432/triptiming
